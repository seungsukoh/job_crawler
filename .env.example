# Shared
APP_ENV=local

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
DATABASE_URL=postgresql+psycopg://job_crawler:job_crawler@localhost:5432/job_crawler
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=job_crawler
POSTGRES_USER=job_crawler
POSTGRES_PASSWORD=job_crawler
ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-for-local-development

# Crawler
CRAWLER_USER_AGENT=job-crawler/0.1 contact:replace-with-email@example.com
CRAWLER_DEFAULT_TIMEOUT_SECONDS=20
CRAWLER_DEFAULT_RATE_LIMIT_SECONDS=3
